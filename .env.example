# FinOps Platform — environment variables
# Copy to .env and fill in values

# CUR generator seed (default: 42)
CUR_SEED=42

# Iceberg warehouse path (default: data/warehouse)
ICEBERG_WAREHOUSE=data/warehouse

# DuckDB file path (default: data/marts.duckdb)
DUCKDB_PATH=data/marts.duckdb

# Infracost API key (required for Step 11+)
# INFRACOST_API_KEY=ico-your-key-here

# Dagster home directory (절대 경로 필수 — 프로젝트 루트 기준으로 직접 설정)
# DAGSTER_HOME=/home/yourname/FinOps/.dagster
