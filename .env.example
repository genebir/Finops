# FinOps Platform — environment variables
# Copy to .env and fill in values

# ── PostgreSQL (Analytics DB) ─────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DBNAME=finops
POSTGRES_USER=finops_app
POSTGRES_PASSWORD=finops_secret_2026

# ── Data paths ────────────────────────────────────────────────────────────────
ICEBERG_WAREHOUSE=data/warehouse
REPORTS_DIR=data/reports

# ── CUR generator ─────────────────────────────────────────────────────────────
CUR_SEED=42

# ── Infracost (선택) ──────────────────────────────────────────────────────────
# INFRACOST_API_KEY=ico-your-key-here
# TERRAFORM_PATH=terraform/sample
# INFRACOST_BINARY=infracost

# ── Alerting (선택) ───────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERT_EMAIL_TO=ops@example.com,oncall@example.com
# ALERT_EMAIL_FROM=finops-bot@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# ── Dagster ───────────────────────────────────────────────────────────────────
# 절대 경로 필수 — 프로젝트 루트 기준으로 직접 설정
# DAGSTER_HOME=/Users/you/PythonProject/Finops/.dagster

# ── Exchange Rate API (선택, Phase 6) ─────────────────────────────────────────
# EXCHANGE_RATE_API_KEY=
